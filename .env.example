# URL e chave pública (anon) do projeto Supabase.
# Local: valores exibidos por `supabase start` / `supabase status`.
# Produção: Dashboard do projeto > Settings > API.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública do site (sem barra no fim). Usada para gerar URLs absolutas das
# imagens de compartilhamento social (Open Graph). Em produção, use o domínio
# real, ex.: https://elevatto.com.br
NEXT_PUBLIC_SITE_URL=http://localhost:3000
